# ──────────────────────────────────────────
# NeuroLens Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────

# ── Keras / TensorFlow model (3D Attention-UNet, Dice 0.9562) ─────────────
# Run: python download_model.py  → then paste the printed path here
# Source: huggingface.co/maryann-gitonga/brain-tumor-segmentation-3d-attention-unet
NEUROLENS_KERAS_MODEL_PATH= D:\NeuroLens\backend\models\trial_4attention_unet_3d


# Path to the pre-trained SwinUNETR model checkpoint (.pt file)
# Leave blank to use the heuristic fallback segmentation
NEUROLENS_MODEL_PATH=

# BraTS dataset root directory
# Should point to the folder containing BraTS20_Training_XXX subdirectories
NEUROLENS_BRATS_ROOT=

# Model mode: "brats" (4-channel) or "single" (1-channel)
NEUROLENS_MODEL_MODE=brats

# Model architecture: "swinunetr" or "unet"
NEUROLENS_MODEL_ARCH=swinunetr

# SwinUNETR configuration
NEUROLENS_MODEL_OUT_CHANNELS=3
NEUROLENS_SWIN_FEATURE_SIZE=48
NEUROLENS_SWIN_USE_CHECKPOINT=false

# Sliding window ROI size for inference
NEUROLENS_INFER_ROI_Z=96
NEUROLENS_INFER_ROI_Y=96
NEUROLENS_INFER_ROI_X=96
